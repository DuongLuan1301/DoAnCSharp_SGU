<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="project_csharp_sgu.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:views="clr-namespace:project_csharp_sgu.Views">

    <TabBar>

        <Tab Title="Home">
            <ShellContent
                ContentTemplate="{DataTemplate views:HomePage}" />
        </Tab>

        <Tab Title="Nearby">
            <ShellContent
                ContentTemplate="{DataTemplate views:NearbyPage}" />
        </Tab>

        <Tab Title="Scan QR">
            <ShellContent
                ContentTemplate="{DataTemplate views:ScannerPage}" />
        </Tab>

    </TabBar>

</Shell>
